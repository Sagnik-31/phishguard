{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.1.0",
  "description": "Analyze websites and emails with PhishGuard phishing forensics.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://phishguard-rouge.vercel.app/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://mail.yahoo.com/*"
  ],
  "action": {
    "default_title": "PhishGuard",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
